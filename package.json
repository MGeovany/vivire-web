{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm build:css && pnpm build:toast && pnpm build:typing-sound",
        "build:css": "tailwindcss -i resources/css/tailwind-input.css -o public/css/tailwind.css --minify",
        "build:toast": "node scripts/build-toast.mjs",
        "build:typing-sound": "node scripts/build-typing-sound.mjs",
        "watch": "tailwindcss -i resources/css/tailwind-input.css -o public/css/tailwind.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.0",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "autoprefixer": "^10.4.2",
        "concurrently": "^9.0.1",
        "esbuild": "^0.28.0",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^4.3.0",
        "vite": "^8.0.0"
    },
    "packageManager": "pnpm@10.34.1",
    "dependencies": {
        "@rexa-developer/tiks": "^0.2.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "sonner": "^2.0.7"
    }
}
