{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/login",      "destination": "/auth/login.php"    },
    { "source": "/register",   "destination": "/auth/register.php" },
    { "source": "/logout",     "destination": "/auth/logout.php"   },
    { "source": "/api/save",   "destination": "/api/save.php"      },
    { "source": "/api/upload", "destination": "/api/upload.php"    },
    { "source": "/",           "destination": "/index.php"         }
  ],
  "env": {
    "SUPABASE_URL":              "@supabase_url",
    "SUPABASE_ANON_KEY":         "@supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "SUPABASE_JWT_SECRET":       "@supabase_jwt_secret"
  }
}
