{
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/public/css/$1" },
    { "source": "/js/(.*)",  "destination": "/public/js/$1"  },
    { "source": "/(.*)",     "destination": "/public/index.php" }
  ]
}
