{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.7.2" }
  },
  "rewrites": [
    { "source": "/css/(.*)",     "destination": "/public/css/$1"     },
    { "source": "/js/(.*)",      "destination": "/public/js/$1"      },
    { "source": "/dict/(.*)",    "destination": "/public/dict/$1"    },
    { "source": "/storage/(.*)", "destination": "/public/storage/$1" },
    { "source": "/favicon.ico",  "destination": "/public/favicon.ico" },
    { "source": "/robots.txt",   "destination": "/public/robots.txt" },
    { "source": "/(.*)",         "destination": "/api/index.php"     }
  ]
}
