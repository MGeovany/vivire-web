APP_NAME=vivire
APP_DESCRIPTION="Minimalist daily journal."
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vivire-web.vercel.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# ─── Sessions ───────────────────────────────────────────────────────────────
# On Vercel (serverless, ephemeral filesystem) use the cookie driver — stateless,
# no DB/file session storage needed. Locally you can use "database".
SESSION_DRIVER=cookie
SESSION_LIFETIME=525600
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Vercel filesystem is read-only except /tmp — keep cache/logs/views off disk.
CACHE_STORE=array
LOG_CHANNEL=stderr
VIEW_COMPILED_PATH=/tmp/views

# ─── Database — Supabase Postgres ───────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database.
# Use the CONNECTION POOLER (port 6543, transaction mode) for serverless.
# DB_PASSWORD is your Supabase database password (NOT the anon/service key).
DB_CONNECTION=pgsql
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<your-supabase-db-password>
DB_SSLMODE=require

# To run migrations locally, use the DIRECT connection (port 5432):
#   DB_HOST=db.<project-ref>.supabase.co
#   DB_PORT=5432
#   DB_USERNAME=postgres

# ─── Media storage — Supabase Storage (S3-compatible) ───────────────────────
# Dashboard → Storage → create a PUBLIC bucket "journal-media".
# S3 keys: Dashboard → Project Settings → Storage → S3 access keys.
MEDIA_DISK=supabase
SUPABASE_S3_KEY=<s3-access-key-id>
SUPABASE_S3_SECRET=<s3-secret-access-key>
SUPABASE_S3_REGION=<region>
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_BUCKET=journal-media
SUPABASE_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/journal-media
